# History files
.Rhistory
.Rapp.history

# Session Data files
.RData

# User-specific files
.Ruserdata

# Example code in package build process
*-Ex.R

# Output files from R CMD build
/*.tar.gz

# Output files from R CMD check
/*.Rcheck/

# RStudio files
.Rproj.user/

# produced vignettes
vignettes/*.html
vignettes/*.pdf

# OAuth2 token, see https://github.com/hadley/httr/releases/tag/v0.3
.httr-oauth

# knitr and R markdown default cache directories
*_cache/
/cache/

# Temporary files created by R markdown
*.utf8.md
*.knit.md

# R Environment Variables
.Renviron

# FLUXNET raw archives and unzipped source files — never commit
data/DE-Tha/raw/
data/DK-Sor/raw/
data/US-MMS/raw/

# Processed FLUXNET CSVs — large files, regenerated by download scripts
data/DE-Tha/*.csv
data/DK-Sor/*.csv
data/US-MMS/*.csv

# SSEM model output — generated by running exercises/01_run_model.Rmd
# (files exceed GitHub's 100 MB limit; regenerated by running the exercises)
data/*.rds
exercises/review_figures/*.rds

# knitr intermediate figure directories (plots are embedded in HTML)
exercises/*_files/
